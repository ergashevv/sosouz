{
  "name": "soso",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:sync-migration-checksums": "node --env-file=.env node_modules/tsx/dist/cli.mjs scripts/sync-migration-checksums.ts",
    "db:baseline": "prisma migrate resolve --applied 20260407100000_baseline",
    "db:push": "prisma db push",
    "db:sync-nuu-tuition": "node --env-file=.env node_modules/tsx/dist/cli.mjs scripts/sync-nuu-tuition.ts",
    "test:azure": "node --env-file=.env node_modules/tsx/dist/cli.mjs scripts/test-azure-openai.ts",
    "warm:hipo-cache": "node --env-file=.env node_modules/tsx/dist/cli.mjs scripts/warm-hipo-cache.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "^1.8.0",
    "next": "16.2.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-country-flag": "^3.1.0",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.82.2"
  }
}
