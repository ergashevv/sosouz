generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ChatRole {
  user
  assistant
}

model UniversityDetails {
  id                    String   @id @default(uuid())
  university_name        String   @unique
  domain                String?
  country               String?
  tuition_fees          String?
  scholarships          Json?    // Array of objects with { name, link }
  programs              Json?    // Array of main study directions/programs
  admission_requirements Json?    // Structured data
  admission_deadline    String?
  detailed_overview     String?  @db.Text
  source_links          Json?    // Array of source URLs used for enrichment
  data_confidence       Float?
  refresh_status        String?  // fresh | stale | partial | failed
  next_refresh_at       DateTime?
  last_ai_refresh_attempt_at DateTime?
  last_updated          DateTime @updatedAt
  /** Official YouTube channel ID (UC…) for Data API; optional. */
  youtube_channel_id    String?
}

model SearchCache {
  id           String   @id @default(uuid())
  query        String   @unique
  results      Json
  last_updated DateTime @updatedAt
}

/** Rows synced from Hipolabs (search responses); used to reduce repeat upstream fetches. */
model UniversityCatalog {
  id              String   @id @default(uuid())
  name            String
  country         String
  alpha_two_code  String
  web_pages       Json
  domains         Json
  state_province  String?
  source          String   @default("hipolabs")
  first_seen_at   DateTime @default(now())
  last_synced_at  DateTime @updatedAt

  @@unique([name, country])
  @@index([country])
  @@index([name])
}

model UniversityLogo {
  id          String   @id @default(uuid())
  domain      String   @unique
  mime_type   String
  image_data  Bytes
  source_url  String?
  fetched_at  DateTime @default(now())
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model User {
  id               String             @id @default(uuid())
  first_name       String
  last_name        String
  email            String?            @unique
  google_sub       String?            @unique
  avatar_url       String?
  auth_provider    String             @default("phone")
  has_password     Boolean            @default(true)
  phone_country    String
  phone_e164       String             @unique
  password_hash    String
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  sessions         UserSession[]
  conversations    ChatConversation[]
}

model UserSession {
  id           String   @id @default(uuid())
  user_id      String
  token        String   @unique
  expires_at   DateTime
  created_at   DateTime @default(now())
  last_used_at DateTime @updatedAt
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model ChatConversation {
  id           String        @id @default(uuid())
  user_id      String
  title        String
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([user_id, updated_at])
}

model ChatMessage {
  id               String           @id @default(uuid())
  conversation_id  String
  role             ChatRole
  content          String           @db.Text
  created_at       DateTime         @default(now())
  conversation     ChatConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([conversation_id, created_at])
}

model ChatMessageFeedback {
  id                     String   @id @default(uuid())
  user_id                String
  conversation_id        String
  message_id             String   @unique
  helpful                Boolean
  language               String?
  recommendation_country String?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@index([user_id, created_at])
  @@index([conversation_id, created_at])
}
